# 详见 https://github.com/github/gitignore/blob/main/Node.gitignore

# 依赖文件
node_modules/
/.pnp
.pnp.js

# 测试文件
/coverage

# 生产构建文件
/dist
/build

# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


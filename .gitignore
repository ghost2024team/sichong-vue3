.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 环境变量
.env
.env.local
.env.*.local

# 临时文件
*.tmp
*.temp
.cache

# WindiCSS 临时文件
.windi/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# 其他
.vercel
